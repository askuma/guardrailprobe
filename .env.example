# GuardrailProbe environment variables
# Copy this file to .env and fill in your credentials.
# Never commit .env to version control.

# ── Lakera Guard ──────────────────────────────────────────────────────────────
LAKERA_GUARD_API_KEY=

# ── NeMo LLM provider — auto-detected, first match wins ──────────────────────
# Without any key NeMo uses colang pattern-matching only (still covers LLM01).
# OpenAI (or use NEMO_OPENAI_API_KEY as a NeMo-specific alias)
OPENAI_API_KEY=
# Override the model used by NeMo when OPENAI_API_KEY / NEMO_OPENAI_API_KEY is set.
NEMO_OPENAI_MODEL=gpt-4o-mini

# OpenRouter — free-tier OpenAI-compatible LLM gateway (recommended for NeMo).
# Sign up at https://openrouter.ai (no credit card required) and create an API key.
# Free models (no charges, rate-limited): any model name with a ":free" suffix.
# Recommended free model for NeMo intent classification:
#   meta-llama/llama-3.1-8b-instruct:free   (fast, good instruction following)
#   google/gemma-2-9b-it:free               (alternative)
#   mistralai/mistral-7b-instruct:free      (smaller alternative)
# Browse all free models at: https://openrouter.ai/models?q=free
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# ── Azure Content Safety + Prompt Shields (share the same endpoint/key) ──────
AZURE_CONTENT_SAFETY_ENDPOINT=https://your-instance.cognitiveservices.azure.com
AZURE_CONTENT_SAFETY_KEY=

# ── Azure OpenAI (alternative LLM backend for NeMo) ──────────────────────────
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-instance.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ── Ollama (local LLM for NeMo, no API key needed) ───────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# ── Anthropic (alternative LLM backend for NeMo) ─────────────────────────────
ANTHROPIC_API_KEY=

# ── OpenAI Moderation ─────────────────────────────────────────────────────────
# Reuses OPENAI_API_KEY above — no extra variable needed.

# ── AWS Bedrock ───────────────────────────────────────────────────────────────
AWS_DEFAULT_REGION=us-east-1
AWS_BEDROCK_GUARDRAIL_ID=
# AWS credentials (or use IAM role / aws configure)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── Custom HTTP guardrail endpoint (benchmarks a generic REST guardrail API) ─
GA_GUARD_API_URL=https://your-guardrail-api/check

# ── Ollama (local LLM for NeMo, no key needed) ───────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# ── PDF signing ───────────────────────────────────────────────────────────────
# GUARDRAIL_SIGNING_KEY_P12=guardrail_signing.p12
# GUARDRAIL_SIGNING_KEY_PASS=
# GUARDRAIL_TSA_URL=http://timestamp.digicert.com

# ── Misc ──────────────────────────────────────────────────────────────────────
# GUARDRAILPROBE_SKIP_SPACY=1   # skip spaCy model download (CI / constrained envs)
