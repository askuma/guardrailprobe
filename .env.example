# GuardrailProbe environment variables
# Copy this file to .env and fill in your credentials.
# Never commit .env to version control.

# ── Lakera Guard ──────────────────────────────────────────────────────────────
LAKERA_GUARD_API_KEY=

# ── OpenAI Moderation (also used by NeMo if no other LLM backend is set) ─────
OPENAI_API_KEY=

# ── OpenRouter (alternative LLM backend for NeMo) ────────────────────────────
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# ── Azure Content Safety + Prompt Shields (share the same endpoint/key) ──────
AZURE_CONTENT_SAFETY_ENDPOINT=https://your-instance.cognitiveservices.azure.com
AZURE_CONTENT_SAFETY_KEY=

# ── Azure OpenAI (alternative LLM backend for NeMo) ──────────────────────────
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-instance.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# ── Anthropic (alternative LLM backend for NeMo) ─────────────────────────────
ANTHROPIC_API_KEY=

# ── AWS Bedrock ───────────────────────────────────────────────────────────────
AWS_DEFAULT_REGION=us-east-1
AWS_BEDROCK_GUARDRAIL_ID=
# AWS credentials (or use IAM role / aws configure)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── Custom HTTP guardrail endpoint (benchmarks a generic REST guardrail API) ─
GA_GUARD_API_URL=https://your-guardrail-api/check

# ── Ollama (local LLM for NeMo, no key needed) ───────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# ── PDF signing ───────────────────────────────────────────────────────────────
# GUARDRAIL_SIGNING_KEY_P12=guardrail_signing.p12
# GUARDRAIL_SIGNING_KEY_PASS=
# GUARDRAIL_TSA_URL=http://timestamp.digicert.com

# ── Misc ──────────────────────────────────────────────────────────────────────
# GUARDRAILPROBE_SKIP_SPACY=1   # skip spaCy model download (CI / constrained envs)
